DESTDIR        = release\ #avoid trailing-slash linebreak
TARGET         = Kala.exe
DESTDIR_TARGET = release\Kala.exe

####### Build rules

first: all
all: Makefile.Release  release/Kala.exe

release/Kala.exe: C:/Qt/6.10.1/mingw_64/lib/libQt6Widgets.a C:/Qt/6.10.1/mingw_64/lib/libQt6Gui.a C:/Qt/6.10.1/mingw_64/lib/libQt6Concurrent.a C:/Qt/6.10.1/mingw_64/lib/libQt6Core.a C:/Qt/6.10.1/mingw_64/lib/libQt6EntryPoint.a ui_kalamain.h ui_container.h ui_dialogNewProject.h ui_easingdialog.h ui_scaledialog.h ui_scorecanvas.h ui_sounitbuilder.h $(OBJECTS) 
	$(LINKER) $(LFLAGS) -o $(DESTDIR_TARGET) @release\object_script.Kala.Release $(LIBS)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release ..\..\Kala.pro -spec win32-g++ "CONFIG+=debug" "CONFIG+=qml_debug"

qmake_all: FORCE

